{
  "security_tiers": {
    "open": "🟢 Safe to send to LLM",
    "local": "🔒 Agent reads privately, never sent to LLM",
    "locked": "🔴 Encrypted, requires passphrase to access"
  },
  "defaults": {
    "default_tier": "open",
    "max_aliases_per_branch": 3,
    "min_similarity_threshold": 0.65,
    "recency_weight": 0.15,
    "recency_fade_days": 90,
    "outdated_penalty": 0.5,
    "importance_weight": 0.10,
    "confidence_threshold": 0.75,
    "ambiguity_gap": 0.1,
    "default_top_k": 5,
    "startup_top_k": 10,
    "embedding_model": "nomic-embed-text",
    "search_fallback_order": ["semantic", "tfidf", "keyword"],
    "correction_match_threshold": 0.4
  },
  "corrections": {
    "always_surface": true,
    "never_expire": true,
    "default_importance": 5,
    "sources": ["boss", "self", "peer", "system"]
  },
  "active_recall": {
    "enabled": true,
    "require_verification": false,
    "warn_on_critical_corrections": true
  },
  "branch_security": {}
}
